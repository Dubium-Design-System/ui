{
	"name": "@dubium/ui",
	"private": false,
	"version": "0.0.30",
	"type": "module",
	"homepage": "https://dubium-design-system.github.io/ui/",
	"bugs": {
		"url": "https://github.com/Dubium-Design-System/ui/issues"
	},
	"repository": "https://github.com/Dubium-Design-System/ui/",
	"description": "A lightweight and customizable UI component library for React, designed to streamline the development of modern web applications. @dubium/ui includes an array of responsive, accessible, and reusable UI components, optimized for performance and ease of use.",
	"keywords": [
		"react",
		"ui",
		"components",
		"design-system",
		"library",
		"frontend"
	],
	"author": "https://github.com/DubiumEkb",
	"license": "MIT",
	"scripts": {
		"dev": "vite --port 5000",
		"clean": "rimraf dist",
		"build": "npm run clean && npm run build:js && npm run build:types",
		"build:vite": "tsc -b && vite build",
		"build:js": "vite build",
		"build:types": "tsc -p tsconfig.build.json",
		"lint": "eslint .",
		"preview": "vite preview",
		"version:push": "npm run build && npm publish --access=public"
	},
	"peerDependencies": {
		"@dubium/hooks": "^0.0.6",
		"react": " ^18.0.0 || ^19.0.0",
		"react-dom": "^18.0.0 || ^19.0.0"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@types/node": "^25.3.3",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react-swc": "^4.3.0",
		"eslint": ">=9.27.0",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.5.2",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"rimraf": "^6.1.3",
		"rollup-plugin-visualizer": "^7.0.1",
		"sass": "^1.98.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.57.2",
		"vite": "^8.0.3",
		"vite-plugin-lib-inject-css": "^2.2.2"
	},
	"sideEffects": [
		"**/*.css"
	],
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"dependencies": {
		"clsx": "^2.1.1",
		"uuid": "^13.0.0"
	}
}
